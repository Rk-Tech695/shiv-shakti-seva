generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                   Int        @id @default(autoincrement())
  name                 String
  mobile_number        String     @unique
  whatsapp_number      String?
  dob                  DateTime?
  total_donated_amount Float      @default(0)
  role                 Role       @default(USER)
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt
  donations            Donation[]
}

enum Role {
  USER
  ADMIN
}

model Admin {
  id       Int    @id @default(autoincrement())
  username String @unique
  password String
}

model Donation {

  id             Int               @id @default(autoincrement())

  userId         Int

  user           User              @relation(fields: [userId], references: [id])

  amount         Float

  paymentMode    PaymentMode

  transactionId  String?

  paymentHolderName String?

  utrNumber      String?

  proofImage     String?

  receivedBy     String?

  verifiedBy     String?

  verifiedAt     DateTime?

  status         DonationStatus    @default(PENDING)

  invoiceUrl     String?

  createdAt      DateTime          @default(now())

}

enum PaymentMode {
  RAZORPAY
  UPI
  BANK_TRANSFER
  CASH
}

enum DonationStatus {
  PENDING
  SUCCESS
  FAILED
}


model Expense {

  id           Int           @id @default(autoincrement())

  amount       Float

  purpose      String

  sourceType   ExpenseMode

  handledBy    String

  description  String?

  createdAt    DateTime      @default(now())

}

enum ExpenseMode {
  CASH
  BANK
}

model Event {

  id           Int       @id @default(autoincrement())

  title        String

  description  String?

  eventDate    DateTime

  location     String?

  bannerImage  String?

  createdAt    DateTime  @default(now())

}



model Trustee {
  id          Int      @id @default(autoincrement())
  name        String
  mobile      String
  designation String
  createdAt   DateTime @default(now())
}

model BhavanBooking {

  id             Int      @id @default(autoincrement())

  name           String

  mobile         String

  totalPersons   Int

  arrivalDate    DateTime

  departureDate  DateTime

  stayType       String

  note           String?

  assignedRoom   String?

  status         String   @default("PENDING")

  createdAt      DateTime @default(now())

}


model AppSetting {

  id                     Int    @id @default(1)

  maxDevoteesPerBooking  Int    @default(5)

}

