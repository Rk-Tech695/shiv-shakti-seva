generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                   Int        @id @default(autoincrement())
  name                 String
  mobile_number        String     @unique
  whatsapp_number      String?
  dob                  DateTime?
  total_donated_amount Float      @default(0)
  role                 Role       @default(USER)
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt
  donations            Donation[]
  @@map("user")
}

enum Role {
  USER
  ADMIN
}

model Admin {
  id       Int    @id @default(autoincrement())
  username String @unique
  password String
  @@map("admin")
}

model Donation {

  id             Int               @id @default(autoincrement())

  userId         Int

  user           User              @relation(fields: [userId], references: [id])

  amount         Float

  paymentMode    PaymentMode

  transactionId  String?

  paymentHolderName String?

  utrNumber      String?

  proofImage     String?

  receivedBy     String?

  verifiedBy     String?

  verifiedAt     DateTime?

  status         DonationStatus    @default(PENDING)

  invoiceUrl     String?

  isPublic       Boolean           @default(true)

  createdAt      DateTime          @default(now())

  @@map("donation")

}

model DonationSetting {

  id          Int    @id @default(1)

  goalAmount  Float  @default(73000000)

  @@map("donationsetting")

}

enum PaymentMode {
  RAZORPAY
  UPI
  BANK_TRANSFER
  CASH
}

enum DonationStatus {
  PENDING
  SUCCESS
  FAILED
}


model Expense {

  id           Int           @id @default(autoincrement())

  amount       Float

  purpose      String

  sourceType   ExpenseMode

  handledBy    String

  description  String?

  createdAt    DateTime      @default(now())

  @@map("expense")

}

enum ExpenseMode {
  CASH
  BANK
}

model Event {

  id           Int       @id @default(autoincrement())

  title        String

  description  String?

  eventDate    DateTime

  location     String?

  bannerImage  String?

  createdAt    DateTime  @default(now())

  @@map("event")

}



model Trustee {
  id          Int      @id @default(autoincrement())
  name        String
  mobile      String
  designation String
  createdAt   DateTime @default(now())

  @@map("trustee")
}

model BhavanRoom {

  id          Int      @id @default(autoincrement())

  name        String

  type        String

  totalBeds   Int

  occupiedBeds Int     @default(0)

  isHall      Boolean  @default(false)

  isActive    Boolean  @default(true)

  createdAt   DateTime @default(now())

  bookings    BhavanBooking[]

  @@map("bhavanroom")
}

model BhavanBooking {

  id               Int      @id @default(autoincrement())

  groupName        String

  mobileNumber     String

  totalPersons     Int

  totalMales       Int

  totalFemales     Int

  jalDate          DateTime

  arrivalDate      DateTime

  departureDate    DateTime

  note             String?

  status           BhavanStatus @default(PENDING)

  assignedRoomId   Int?

  assignedRoom     BhavanRoom? @relation(fields: [assignedRoomId], references: [id])

  createdAt        DateTime @default(now())

  assignedAt       DateTime?

  checkoutAt       DateTime?

  devotees         BhavanDevotee[]

  @@map("bhavanbooking")

}

model BhavanDevotee {

  id             Int      @id @default(autoincrement())

  name           String

  gender         String

  age            Int

  dob            DateTime?

  mobile         String?

  bookingId      Int

  booking        BhavanBooking @relation(fields: [bookingId], references: [id])

  @@map("bhavandevotee")

}

enum BhavanStatus {

  PENDING

  APPROVED

  REJECTED

  COMPLETED

}


model AppSetting {

  id                     Int     @id @default(1)

  maxDevoteesPerBooking  Int     @default(5)

  bhavanBookingEnabled   Boolean @default(true)

  bhavanBookingMessage   String?

  @@map("appsetting")

}

